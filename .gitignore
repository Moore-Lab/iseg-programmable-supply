# KiCad session / lock / backup state — regenerated by the GUI, never source
*.kicad_prl
*-backups/
fp-info-cache
_autosave-*
*.kicad_sch-bak
*.kicad_pcb-bak
*.bak
*~

# Python
__pycache__/
*.pyc

# Editor
.vscode/
.idea/

# NOTE: generated CAD files (.kicad_sch, .kicad_pcb, .kicad_sym, .kicad_mod, gerbers)
# are COMMITTED build artifacts. They are versioned deliberately, alongside the
# generator that produced them, so every commit is a self-consistent pair.
# Do not add them here. See CLAUDE.md rule 1.
